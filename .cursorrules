│   ├── user.py           # User-specific CRUD operations
│   └── [other crud]      # Other model specific CRUD operations

├── models/               # SQLModel database models
│   ├── admin.py         # Admin and permissions models
│   ├── alerts.py        # Alert system models
│   ├── base.py          # Base model classes
